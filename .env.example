# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100

# Queue Configuration
QUEUE_CONCURRENCY=5
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_TYPE=exponential
QUEUE_BACKOFF_DELAY=2000
QUEUE_REMOVE_ON_COMPLETE=100
QUEUE_REMOVE_ON_FAIL=50
QUEUE_MAX_STALLED_COUNT=1
QUEUE_STALLED_INTERVAL=30000

# Worker Configuration
WORKER_POOL_SIZE=10
WORKER_TIMEOUT=300000
WORKER_KILL_TIMEOUT=10000
WORKER_MAX_MEMORY_MB=512
WORKER_SANDBOX=true
WORKER_ALLOWED_COMMANDS=node,npm,python,python3,java,go,ruby,php

# Logging Configuration
LOG_LEVEL=info
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m
LOG_DATE_PATTERN=YYYY-MM-DD
LOG_DIRECTORY=./logs

# Security Configuration
SECURITY_MAX_SCRIPT_LENGTH=100000
SECURITY_MAX_EXECUTION_TIME=600000
SECURITY_ALLOWED_EXTENSIONS=.js,.ts,.py,.java,.go,.rb,.php,.sh
SECURITY_BLOCKED_PATTERNS=rm -rf,sudo,chmod 777,eval(,exec(,system(,child_process,spawn,fork,> /dev/,2>&1
