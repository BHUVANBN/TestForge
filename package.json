{
  "name": "distributed-test-execution-engine",
  "version": "1.0.0",
  "description": "Production-grade distributed test execution engine inspired by cloud testing platforms",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "docker:build": "docker build -t test-execution-engine .",
    "docker:run": "docker-compose up -d",
    "cli": "ts-node src/cli/forge.ts",
    "cli:build": "tsc && chmod +x dist/cli/forge.js"
  },
  "bin": {
    "forge": "./dist/cli/forge.js"
  },
  "keywords": [
    "testing",
    "distributed",
    "queue",
    "worker",
    "typescript",
    "nodejs"
  ],
  "author": "TestForge Team",
  "license": "MIT",
  "dependencies": {
    "@types/dockerode": "^4.0.1",
    "axios": "^1.13.6",
    "bullmq": "^4.15.0",
    "commander": "^14.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dockerode": "^4.0.10",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.4",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.7",
    "@types/node": "^20.8.7",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.6",
    "@types/ws": "^8.5.8",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
